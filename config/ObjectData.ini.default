# ============================================================================
# DUNE LEGACY - UNIT & STRUCTURE DATA CONFIGURATION
# ============================================================================
#
# This file allows you to customize unit and structure properties without
# recompiling the game. This file is located in the config subdirectory of your
# game installation:
#
#   Windows: <game_install_dir>\config\ObjectData.ini
#   Linux:   <game_install_dir>/config/ObjectData.ini
#   macOS:   Dune Legacy.app/Contents/Resources/config/ObjectData.ini
#
# For more information, visit:
# https://dunelegacy.sourceforge.net/website/development/modding.html
#
# ============================================================================
# PROPERTY REFERENCE
# ============================================================================
#
# The following properties are available for structures, units, or both:
#
# Enabled          - Is this unit/structure available (starting units/structures, 
#                    construction yard, factory, starport, reinforcement)?
# HitPoints        - What is the maximum health of this structure/unit?
# Price            - How much does this structure/unit cost?
# Power            - How much power does this structure require? 
#                    Wind traps have negative values because they produce power.
# ViewRange        - How much terrain is revealed when this structure is placed
#                    or this unit is moved?
# Capacity         - How much spice can this structure contain?
# WeaponDamage     - How much damage does the weapon of this unit/turret have?
# WeaponRange      - How far can this unit/turret shoot?
# WeaponReloadTime - How many frames does it take to reload the weapon?
# MaxSpeed         - How fast can this unit move?
# TurnSpeed        - How fast can this unit/turret turn around?
# BuildTime        - How much time does the production of this structure/unit take?
# InfSpawnProp     - What is the probability (in percent) that an infantry soldier
#                    is spawned on destruction?
# Builder          - In what structure can this structure/unit be built? One of:
#                    Invalid, Construction Yard, Barracks, WOR, Light Factory,
#                    Heavy Factory, Hightech Factory
# TechLevel        - What is the minimum required tech level (=mission) for this
#                    structure/unit to be available?
# UpgradeLevel     - What upgrade level (0,1,2,...) must the builder be in to make
#                    this structure/unit available?
# Prerequisite     - What other structures have to exist for this structure/unit
#                    to be available?
#
# NOTE: It depends on the unit/structure if a value is ignored. 
#       For example, an unarmed unit will ignore WeaponRange.
#
# ============================================================================
# HOUSE-SPECIFIC OVERRIDES
# ============================================================================
#
# You can set different values per house by adding a house suffix to any property:
#
# Example:
#   Price = 300          # Default price for all houses
#   Price(A) = 250       # Atreides-specific price
#   Price(H) = 350       # Harkonnen-specific price
#
# House codes:
#   A = Atreides
#   H = Harkonnen
#   O = Ordos
#   F = Fremen
#   S = Sardaukar
#   M = Mercenary
#
# When determining a property value for unit "Tank" of house "Atreides", 
# the game checks in this order:
#   1. Tank/Price(A)     (house-specific for this unit)
#   2. Tank/Price        (default for this unit)
#   3. default unit/Price (fallback default)
#
# ============================================================================
# MULTIPLAYER COMPATIBILITY
# ============================================================================
#
# IMPORTANT: For multiplayer games, every player must have identical 
# ObjectData.ini values. Otherwise the game will desynchronize.
#
# ============================================================================
# DEFAULT VALUES
# ============================================================================
#
# The [default structure] and [default unit] sections provide fallback values
# for any properties not specified in individual unit/structure sections.

# ============================================================================
# MAP SETTINGS
# ============================================================================
#
# These settings control global game behavior based on map size.

[Map Settings]
# Maximum harvesters per house based on map size (when override is not set)
# These are used when "Override max. harvesters" is unchecked in game options
HarvesterLimitSmallMap = 5      # Maps 32x32 or smaller (1024 tiles)
HarvesterLimitMediumMap = 10    # Maps 64x64 or smaller (4096 tiles)
HarvesterLimitLargeMap = 15     # Maps between 64x64 and 128x128 (4096-16384 tiles)
HarvesterLimitHugeMap = 40      # Maps 128x128 or larger (16384+ tiles)

# Maximum units per house based on map size (when override is not set)
# These are used when "Override max. number of units" is unchecked in game options
UnitLimitSmallMap = 25          # Maps 32x32 or smaller (1024 tiles)
UnitLimitMediumMap = 100        # Maps 64x64 or smaller (4096 tiles)
UnitLimitLargeMap = 250         # Maps between 64x64 and 128x128 (4096-16384 tiles)
UnitLimitHugeMap = 300          # Maps 128x128 or larger (16384+ tiles)

