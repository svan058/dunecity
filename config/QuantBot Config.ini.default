# ============================================================================
# GENERAL AI BEHAVIOR
# ============================================================================
#
# Global settings that affect all difficulty levels.
#
# AttackTimerMs          - Time between attack checks (milliseconds)
# AttackThresholdPercent - Don't attack until military reaches this % of limit (0.0-1.0)
# MinMoneyForProduction  - Minimum money needed to queue production

[General Behavior]
AttackTimerMs=90000
AttackThresholdPercent=0.40
MinMoneyForProduction=500
